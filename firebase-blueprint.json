{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "role"]
    },
    "Bet": {
      "title": "Bet",
      "description": "A bet placed by a user on a game period",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "gameId": { "type": "string" },
        "amount": { "type": "number" },
        "selection": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "gameId", "amount", "selection", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit or withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["bkash", "nagad", "rocket"] },
        "accountNumber": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "method", "accountNumber", "status"]
    },
    "Game": {
      "title": "Game",
      "description": "Game period information",
      "type": "object",
      "properties": {
        "periodId": { "type": "string" },
        "resultColor": { "type": "string" },
        "resultNumber": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["periodId", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "bkash": { "type": "string" },
        "nagad": { "type": "string" },
        "rocket": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "bets/{betId}": {
      "schema": "Bet",
      "description": "User bets"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "games/{gameId}": {
      "schema": "Game",
      "description": "Game history and current state"
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Global app settings"
    }
  }
}
